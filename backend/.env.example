# Скопируйте в .env и подставьте свои значения:
#   cp .env.example .env

PORT=8080
MONGO_URI=mongodb://mongodb:27017
JWT_SECRET=смените-на-длинную-случайную-строку

# ─── SMTP: откуда уходит код на почту ───────────────────────────────────────
# Нужны 5 значений (см. таблицу ниже). Пока SMTP_HOST пустой — код только в логах:
#   docker compose logs -f backend

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Примеры SMTP_HOST (выберите свой почтовый сервис):
#   Gmail:    smtp.gmail.com
#   Yandex:   smtp.yandex.ru
#   Mail.ru:  smtp.mail.ru
#   Outlook:  smtp.office365.com

# Пример для Gmail (раскомментируйте и подставьте свои данные):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=myproject@gmail.com
# SMTP_PASSWORD=xxxx xxxx xxxx xxxx
# SMTP_FROM=VR Home <myproject@gmail.com>
