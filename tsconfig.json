{
  "compilerOptions": {
    //"noImplicitAny": false,
    "strict": true,
    "types": ["node"],
    "target": "ES2020",
    "lib": ["DOM", "ES2020"],
    "module": "ESNext",
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": false,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src", "node_modules/@rsbuild/plugin-sass/dist/index.d.ts"],
  "exclude": ["node_modules", "dist"]
}